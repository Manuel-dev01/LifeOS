# Cognee Cloud tenant credentials.
# Copy this file to .env.local and fill in your values from https://platform.cognee.ai
API-Base-URL=https://your-tenant.aws.cognee.ai
API-KEY=your-cognee-api-key

# Deployment URLs.
#  - FRONTEND_APP_URL: where the backend sends the browser after connect
#    (the Vercel frontend), e.g. https://life-os-facing.vercel.app/app
#  - CORS_ORIGINS: comma-separated allowed origins (the *.vercel.app regex is
#    always allowed too). e.g. https://life-os-facing.vercel.app
# FRONTEND_APP_URL=http://localhost:5173/app
# CORS_ORIGINS=http://localhost:5173

# --- Connectors (optional) -------------------------------------------------
# Google (Gmail + Calendar + Drive), ONE app. See README "Connect your Gmail".
# console.cloud.google.com -> enable Gmail/Calendar/Drive APIs -> OAuth consent
# (External, PUBLISH to Production) -> Web OAuth client.
# IMPORTANT: the REDIRECT_URI must be the BACKEND host (Render), NOT the Vercel
# frontend — the provider sends the code to the backend callback. Then register
# that exact URL in the Google console's Authorized redirect URIs.
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret
GOOGLE_REDIRECT_URI=https://lifeos-backend.onrender.com/auth/google/callback

# Notion (optional) — notion.so/my-integrations, Public integration
# NOTION_CLIENT_ID=
# NOTION_CLIENT_SECRET=
# NOTION_REDIRECT_URI=http://localhost:8000/auth/notion/callback

# Slack (optional) — api.slack.com/apps, activate Public Distribution
# SLACK_CLIENT_ID=
# SLACK_CLIENT_SECRET=
# SLACK_REDIRECT_URI=http://localhost:8000/auth/slack/callback
